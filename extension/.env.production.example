# ─── Backend ──────────────────────────────────────────────────────
# Your production Railway service domain (Step 3a of README)
VITE_API_URL=https://your-prod-service.up.railway.app

# ─── Firebase (production project — Step 1c of README) ────────────
# Create a NEW Firebase project for production. Do NOT copy dev values here.
# Get these from: Firebase Console → production project → Project Settings → Your apps → Web app config
VITE_FIREBASE_API_KEY=your-prod-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-prod-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-prod-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-prod-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-prod-sender-id
VITE_FIREBASE_APP_ID=1:your-sender-id:web:your-app-id

# ─── Google OAuth (README Step 1e) ────────────────────────────────
# Client type MUST be "Web application" (NOT "Chrome extension").
# Create in the same Google Cloud project as your production Firebase project.
# Authorized redirect URIs — add each extension ID you use (README Step 5):
#   https://<extension-id>.chromiumapp.org/
# You can use Load unpacked (prod build) BEFORE Chrome Web Store — register that ID first.
# Firebase Console → Authentication → Google → Web client ID (+ client secret if asked; secret only in Firebase, never here).
VITE_GOOGLE_OAUTH_CLIENT_ID=your-prod-web-client-id.apps.googleusercontent.com

# ─── App URLs ─────────────────────────────────────────────────────
VITE_UPGRADE_URL=https://your-prod-service.up.railway.app/upgrade
